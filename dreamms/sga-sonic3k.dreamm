	file[]: crc = E6F01342; size = 3696512; name = SONIC3K.DS2
	file[]: crc = 929B0672; size = 5510144; name = SONIC3K.EXE
    file[]: crc = 62e79a25; size =  462237; name = SonicKnu.pdf
	
end

fragment[pc-en-garfield-common]:
    file[]: crc = 3693a530; size =    489984; name = RUNSONIC.EXE
	file[]: crc = efb60a8f; size =    992768; name = MIDIOUT.DLL
	file[]: crc = E6F01342; size =   3696512; name = SONIC3K.DS2
    file[]: crc = 929b0672; size =   5510144; name = SONIC3K.EXE
	file[]:									  name = README.TXT

end

fragment[pc-jp-common]:
	file[]: crc = 5E1019D4; size = 5331;	  name = README_J.TXT
	file[]: crc = E08160E7; size = 1373;	  name = README_E.TXT
	file[]: crc = efb60a8f; size =    992768; name = MIDIOUT.DLL
    file[]: crc = 3693a530; size =    489984; name = RUNSONIC.EXE
    file[]: crc = e6f01342; size =   3696512; name = SONIC3K.DS2
    file[]: crc = 929b0672; size =   5510144; name = SONIC3K.EXE


end

