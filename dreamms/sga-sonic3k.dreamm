//
// Sonic & Knuckles Collection
//
desc[sga-sonic3k]:

name = Sonic & Knuckles Collection
icon = sga-sonic3k.png
machine = pc
rootpath = C:\Sega\Sonic3k
launch = "$(rootpath)\$(EXENAME).EXE"
osenv = windows 95
filter = nonlucas, action, sonic, sega
audiohw = gmidi
winres = 640x480x16
EXENAME = RUNSONIC

//INI Settings
DEBUG = 0
FRAMEDROP = 1
MODEX = 1
SONICGAME = 0
ISDEMO = 0
LANGMODE = 0

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)



//
// show warning for debug mode keys
//
warning[s3debug]:
//condition = $(DEBUG)
    text = Debug Mode requires numeric keypad keys turned on. Use keypad keys [1], [2] and [3] to replicate the [A], [B] and [C] buttons on a SEGA Mega Drive or SEGA Genesis controller.
end

//
// game mode configuration
//
config[gamemode]:
	title = Mode Select
		option[select]: name = Launcher; EXENAME = RUNSONIC; ISDEMO = 0
		option[game1]: name = Sonic the Hedgehog 3; EXENAME = SONIC3K; SONICGAME = 2; ISDEMO = 0; condition = is_game()
		option[game2]: name = Sonic & Knuckles; EXENAME = SONIC3K; SONICGAME = 1; ISDEMO = 0; condition = is_game()
		option[game3]: name = Sonic 3 & Knuckles; EXENAME = SONIC3K; SONICGAME = 0; ISDEMO = 0; condition = is_game()
		option[game4]:name = Sonic 3 & Knuckles (Demonstration) ; EXENAME = SONIC3K; SONICGAME = 0; ISDEMO = 1; condition = is_game()
		option[game5]:name = Sonic 3 & Knuckles (Trial); EXENAME = SONIC3K; SONICGAME = 0; ISDEMO = 2
		

end

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[mt32]:    name = $(MT32_NAME);    audiohw = mt32
    option[gmidi]:   name = $(GMIDI_NAME);   audiohw = gmidi; priority = 1
end

//
// Debug Mode Configuration
//
config[debugmode]:
	title = Debug Mode
		option[dboff]: name = Off; DEBUG = 0
		option[dbon]: name = On; DEBUG = 1
		
end

//
// Framedrop Configuration
//
config[framedrop]:
	title = Frame Drop
		option[fdoff]: name = Off; FRAMEDROP = 0
		option[fdon]: name = On; FRAMEDROP = 1; priority = 1
		
end

//
// video configuration
//
config[video]:
    title = Video Configuration
    option[window]:  name = Cropped to Window; wincrop = true; priority = 1
    option[desktop]: name = Full Desktop;      wincrop = false
end

//
//V1.0 System File
//
dynamicfile[]:
    path = C:\WINDOWS\S3K.INI
    contents = [[[$(CRLF)
		[Debug]
		DebugMode="$$(DEBUG)"
		EnableFrameDrop="$$(FRAMEDROP)"
		MukaiDropFrame=0
		ShowFrameCount=0
		EnableFrameCapture=0
		UseModeX=0
		NoSoundEffect=0
		CDCheckEnable=0
		SonicGameMode="$$(SONICGAME)"
		BGMMode=2
		GameMode="$$(ISDEMO)"
		LangMode="$$(LANGMODE)"
    ]]]
end

//
// Fragments of Core Files for Each Release
//
fragment[demo]:
    file[]: crc = efb60a8f; size =    992768; name = MIDIOUT.DLL
    file[]: crc = af4a9cdd; size =    489984; name = RUNSONIC.EXE
    file[]: crc = e6f01342; size =   3696512; name = SONIC3K.DS2
end

fragment[pc-en-common]:
    file[]: crc = 3693A530; size =  489984; name = RUNSONIC.EXE
	file[]: crc = EFB60A8F; size =  992768; name = MIDIOUT.DLL
	file[]: crc = 27857268; size =    1977; name = SONIC.CNT
	file[]: crc = B97B0755; size = 2574497; name = SONIC.HLP
	file[]: crc = E6F01342; size = 3696512; name = SONIC3K.DS2
	file[]: crc = 929B0672; size = 5510144; name = SONIC3K.EXE
end

