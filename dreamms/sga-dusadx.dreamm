//
// Daytona USA Deluxe
//
desc[sga-dusadx]:

name = Daytona USA Deluxe
icon = sga-dusadx.png
machine = pc
rootpath = C:\Sega\DAYTONA_DLX
launch = "$(rootpath)\game\$(EXENAME).exe"
osenv = windows 95
filter = sega, nonlucas, arcade, netplay
winres = 640x480x16
EXENAME = DAYTONA USA Deluxe
CDLABEL = DAYTONA_DLX

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD; optional = true

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)

//
// Common Retail Files
//
