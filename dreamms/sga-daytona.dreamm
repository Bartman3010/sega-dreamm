//
// Daytona USA
//
desc[sga-daytona]:

name = Daytona USA
icon = sga-daytona.png
machine = pc
rootpath = C:\Sega\DAYTONA
launch = "$(rootpath)\$(EXENAME).exe"
osenv = windows 95
filter = sega, nonlucas, racing, arcade
winres = 640x480x16
EXENAME = daytona
CDLABEL = DAYTONA USA
maxfps = 20

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD; optional = true

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)

