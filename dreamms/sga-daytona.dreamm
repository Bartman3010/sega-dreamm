    name = English V1.1 EXPERT
	imports = common
    anchorfile = DAYTONA.EXE
	anchordepth = 2
	//CD-ROM
    file[]: crc = dbe47e49; size =     74240; name = CD\DAYUS.DLL
    file[]: 								  name = CD\README.TXT
