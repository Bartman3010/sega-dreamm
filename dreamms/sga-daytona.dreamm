//    file[]: crc = 2ab04125; size =     10855; name = CD\HLP\DAYTONAE.GID	
	file[]: name = CD\CDDA.SOU; cdda = 8/58/35/32/298/258/283/291/10/11/11/11/36/39/39/39/11/25/258/283/288
	
	CDLABEL = DAYTONA_USA
end

