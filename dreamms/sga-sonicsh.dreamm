//
// Sonic's Schoolhouse
//
desc[sga-sonicsh]:

name = Sonic's Schoolhouse
icon = sga-sonicsh.png
machine = pc
osenv = windows 95
filter = nonlucas
rootpath = C:\Sega\Sonicsh
launch = "$(rootpath)\$(EXEPATH).exe"
audiohw = gmidi
winres = 640x480x8
EXEPATH = sonic
//
// filesystem
//
mount[]: vpath = C:\; 			      srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath);         srcpath = $(ifsinstallpath)
mount[]: vpath = C:\WINDOWS\SYSTEM32; srcpath = $(ifsinstallpath) // for WAVMIX32.DLL for Answer Hunt Prototype

//V1.0 System File
dynamicfile[]:
    path = C:\WINDOWS\SONIC.INI
    contents = [[[$(CRLF)
		[PATHS]
		Tex=C:\Sega\Sonicsh\tex\
		Wav=C:\Sega\Sonicsh\wav\
		AVI=C:\Sega\Sonicsh\avi\
		MAP=C:\Sega\Sonicsh\map\
		Art=C:\Sega\Sonicsh\art\
		MIDI=C:\Sega\Sonicsh\midi\
		[Setup]
		GraphicsQuality=1

    ]]]
end

//V1.1 System File
dynamicfile[]:
    path = C:\WINDOWS\SONICSH.INI
    contents = [[[$(CRLF)
		[PATHS]
		Tex=C:\Sega\Sonicsh\tex\
		Wav=C:\Sega\Sonicsh\wav\
		AVI=C:\Sega\Sonicsh\avi\
		MAP=C:\Sega\Sonicsh\map\
		Art=C:\Sega\Sonicsh\art\
		MIDI=C:\Sega\Sonicsh\midi\
		[Setup]
		GraphicsQuality=1

    ]]]
end

//05/16/1996 Prototype System File
dynamicfile[]:
    path = C:\WINDOWS\AH.INI
    contents = [[[$(CRLF)
		[PATHS]
		Tex=C:\Sega\Sonicsh\tex\
		Wav=C:\Sega\Sonicsh\wav\
		AVI=C:\Sega\Sonicsh\avi\
		MAP=C:\Sega\Sonicsh\map\
		Art=C:\Sega\Sonicsh\art\
		MIDI=C:\Sega\Sonicsh\midi\
//		[Setup]
//		GraphicsQuality=1

    ]]]
end

//To add Wavmix.ini for Prototype
dynamicfile[]:
    path = C:\WINDOWS\WAVEMIX.INI
    contents = [[[$(CRLF)
        [general]
        ShowDevices=0

        [default]
        Remix=1
        GoodWavePos=1
        WaveBlocks=4
        WaveBlockLen=0
        SamplesPerSec=22

        [DREAMM Wave]
        Remix=1
        GoodWavePos=1
        WaveBlocks=4
        WaveBlockLen=688
        SamplesPerSec=22
    ]]]
end

//
//Auto install Script
//
script[autoinstaller]:
	condition = is_installer()
	code = [[[$(CRLF)
		if(!prop("noautoinstall"))
		{
			input_lockout(true);
			$(AUTOINSTALL_SCRIPT)
			input_lockout(false);
		}
	]]]
end

fragment[install-base95]:
	//rootpath = C:\
	launch = $(rootpath)\Setup32.exe
	AUTOINSTALL_SCRIPT = [[[$(CRLF)
		wait("wintitle", "Welcome");
		sleep(200); wincontrol_click(1);
		sleep(200); wincontrol_click(1); //Installing process goes here
		sleep(600); wincontrol_click(1);
		wait("wintitle", "Setup Complete");
		//sleep(200); wincontrol_click(1);
	]]]

end

fragment[install-base31]:
	//rootpath = C:\
	launch = $(rootpath)\Setup16.exe
	AUTOINSTALL_SCRIPT = [[[$(CRLF)
		wait("wintitle", "Welcome");
		sleep(200); wincontrol_click(1);
		sleep(200); wincontrol_click(1); //Installing process goes here
		sleep(600); wincontrol_click(1);
		wait("wintitle", "Setup Complete");
		//sleep(200); wincontrol_click(1);
	]]]

end

