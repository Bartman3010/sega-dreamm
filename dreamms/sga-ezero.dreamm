//
// Enemy Zero
//
desc[sga-ezero]:

name = Enemy Zero
icon = sga-ezero.png
machine = pc
rootpath = C:\Sega\Enemy Zero
launch = "$(rootpath)\$(EXENAME).exe"
osenv = windows 98
winres = 640x480x16
filter = nonlucas
EXENAME = EZERO

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)/LOCAL
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISK1; disc = 1; attributes = 8; contents = $(NULL)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISK2; disc = 2; attributes = 8; contents = $(NULL)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISK3; disc = 3; attributes = 8; contents = $(NULL)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISK4; disc = 4; attributes = 8; contents = $(NULL)

//
// warnings
//
warning[discs]:
    text = This game requires manual disc swapping. You will need to manually change discs when asked. Use the in-game menu or Alt/Cmd+1 to insert disc 1, Alt/Cmd+2 to insert disc 2, Alt/Cmd+3 to insert disc 3 and Alt/Cmd+4 to insert disc 4.
end

game[pc-cd-en-fr-ge]:
	name = English, French, German, Spanish, Italian CD
	anchorfile = EZERO.EXE
	anchordepth = 1
