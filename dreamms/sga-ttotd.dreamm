//
// The Typing of the Dead
//
desc[sga-ttotd]:

name = The Typing of the Dead
icon = sga-ttotd.png
machine = pc
rootpath = C:\Sega\TTOTD
launch = "$(rootpath)\$(EXENAME).exe"
osenv = windows 98
winres = 640x480x32
EXENAME = Todus
filter = nonlucas, netplay

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD

//
// dummy game description;
//
game[pc-en-cd-us]:
    name = English US
    anchorfile = Todus.exe
