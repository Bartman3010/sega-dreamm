//
// Virtua Fighter 2
//
desc[sga-vf2]:

name = Virtua Fighter 2
icon = sga-vf2.png
machine = pc
rootpath = C:\Sega\VF2
launch = "$(rootpath)\$(EXENAME).EXE"
osenv = windows 95
filter = nonlucas, fighting, netplay, arcade
winres = 640x480x8
EXENAME = VF2

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD; optional = true

//
// dynamic files
//
dynamicfile[]: path = D:\VF2; attributes = 8; contents = $(NULL)


//
//Auto install Script
//
script[autoinstaller]:
	condition = is_installer()
	code = [[[$(CRLF)
		if(!prop("noautoinstall"))
		{
			input_lockout(true);
			$(AUTOINSTALL_SCRIPT)
			input_lockout(false);
		}
	]]]
end

fragment[install-base]:
	rootpath = D:\
	launch = D:\Setup.exe
	AUTOINSTALL_SCRIPT = [[[$(CRLF)
		wait("wintitle", "Welcome");
		sleep(200); wincontrol_click(1);
		sleep(200); wincontrol_click(1); //Installing process goes here
		sleep(600); wincontrol_click(1);
		
	]]]

end


