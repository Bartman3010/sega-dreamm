//
// Bug Too! launch template
//
desc[sga-bugtoo]:

name = Bug Too!
icon = sga-bugtoo.png
machine = pc
rootpath = C:\Sega\BugToo!
launch = $(rootpath)\$(EXENAME).EXE
osenv = windows 95
filter = nonlucas
CDLABEL = BUGTOO
EXENAME = BUGTOO!
//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath);   srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)

fragment[common]:
	file[]: crc = C7128B56; size =    143872; name = DUKDLL95.DLL
	file[]: crc = CE3C3CED; size =    144384; name = MSS32.DLL
