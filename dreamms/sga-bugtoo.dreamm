//
// Bug Too! (Europe)
//
game[pc-en-cd-eu]:
    name = English EU
	imports = common
    anchorfile = ANCNTSEL.BFF
	anchordepth = 1
    file[]: crc = 2d0056f4; size =    628736; name = BUGTOO!.EXE
	
    file[]: crc = 527eb2b1; size =   4123165; name = CD\DATA\GARDEN3.BFF
    file[]: crc = 109e57d2; size =   8080602; name = CD\DATA\WIN2.AVI
	
	file[]: name = CDDA.SOU; cdda = 221/143/262/292/138/269/289/214/154/112/93
	
	CDLABEL = DEMO
	
end

//
// Bug Too! (USA)
//
game[pc-en-cd-us]:
    name = English US
	imports = common
    anchorfile = ANCNTSEL.BFF
	anchordepth = 1
    file[]: crc = EEC5A580; size =    629760; name = BUGTOO!.EXE

    file[]: crc = 15ec9733; size =   4123165; name = CD\DATA\GARDEN3.BFF
    file[]: crc = 109e57d2; size =   8080602; name = CD\DATA\WIN2.AVI
	
