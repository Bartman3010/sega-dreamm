game[pc-cd-en]:
	name = English CD
	imports = common
	anchorfile = V_ON.EXE
	anchordepth = 1
    file[]: crc = 1f75c031; size =      1182; name = VON.CNT
    file[]: crc = 2a2ef96c; size =   1008820; name = VON.HLP
    file[]: crc = d292113e; size =      3987; name = README.TXT
	
	//locale = en_US
	
end

