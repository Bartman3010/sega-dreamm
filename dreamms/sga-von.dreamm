//
// Cyber Troopers - Virtual On
//
desc[sga-von]:

name = Cyber Troopers - Virtual On
icon = sga-von.png
machine = pc
rootpath = C:\Sega\VON
launch = "$(rootpath)\$(EXENAME).exe"
osenv = windows 98
filter = nonlucas, netplay
winres = 640x480x16
EXENAME = V_ON
NETWORKMODE = 0
CDLABEL = VON

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD; optional = true

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)

