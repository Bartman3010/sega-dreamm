    name = Network Patch
	upgradeids = pc-cd-us-en, pc-cd-us-en-EXPERT, pc-cd-us-ge, pc-cd-us-ge-EXPERT, pc-cd-us-fr, pc-cd-us-fr-EXPERT, pc-cd-us-sp, pc-cd-us-sp-rv1, pc-cd-us-sp-EXPERT, pc-cd-us-it, pc-cd-us-it-EXPERT, pc-cd-jp-jp, pc-cd-jp-en, pc-cd-jp-ge, pc-cd-jp-fr, pc-cd-jp-sp, pc-cd-jp-it,  pc-cd-eu-en, pc-cd-eu-en-rev2, pc-cd-eu-it, pc-cd-eu-it-rev2, pc-cd-eu-fr, pc-cd-eu-fr-rev2, pc-cd-eu-ge, pc-cd-eu-ge-rev2, pc-cd-eu-sp, pc-cd-eu-sp-rev2
    anchorfile = sr_net.exe
	NETWORKMODE = file_exists("$$(rootpath)\\sr_net.exe")
    file[]: crc = cf94dbd3; size =   1077248; name = sr_net.exe
end

