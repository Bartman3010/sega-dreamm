//
// Sonic R
//
desc[sga-sonicr]:

name = Sonic R
icon = sga-sonicr.png
machine = pc
rootpath = C:\Sega\SonicR
launch = "$(rootpath)\$(EXENAME).exe"
osenv = windows 98
filter = nonlucas, racing, sonic, netplay
winres = 640x480x16
EXENAME = SONICR
NETWORKMODE = 0
CDLABEL = SONICR

//
// filesystem
//
mount[]: vpath = $(rootpath);  srcpath = $(ifsupgradepath); writable = true; condition = is_upgrader()
mount[]: vpath = C:\;          srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath);  srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)

//
// autoinstall script
//
script[autoinstall]:
    condition = is_installer() || is_upgrader()
    code = [[[$(CRLF)
        if (!prop("noautoinstall"))
        {
            input_lockout(true);
            $(AUTOINSTALL_SCRIPT)
            input_lockout(false);
        }
    ]]]
end

//
// Network Mode Toggle
//
config[network]:
	title = Network Mode
	option[neton]: name = On; EXENAME = SR_NET; condition = $(NETWORKMODE)
	option[netoff]: name = Off; EXENAME = SONICR; condition = $(NETWORKMODE)
end

//
// EU REV00 Common Files
//
fragment[eu-cd-common]:
	file[]: crc = 75ab6a2e; size =   1263104; name = sonicr.exe
    file[]: crc = 4bb84d39; size =    921600; name = bin\end\amy.raw
    file[]: crc = 3e5f5232; size =    921600; name = bin\titles\titles.raw\
	CDLABEL = SONICR
end

//
// US Common Files
//
fragment[us-cd-common]:
	imports = eu-cd-common
    file[]: crc = 7f8e8b74; size =     25557; name = CITY\CITY07.RAW
	CDLABEL = SONICR
end

//
// JP Common Files
//
fragment[jp-cd-common]:
    file[]: crc = 717d0e39; size =   1268736; name = sonicr.exe
    file[]: crc = 9dd81bb6; size =    921600; name = bin\end\Amy.raw
    file[]: crc = 42e49a13; size =    921600; name = BIN\titles\titles.raw
	CDLABEL = SONICR
end

