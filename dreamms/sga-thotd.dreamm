//
// The House of the Dead
//
desc[sga-thotd]:

name = The House of the Dead
icon = sga-thotd.png
machine = pc
rootpath = C:\Sega\THOTD
launch = $(rootpath)\$(EXENAME).exe $(CMDLINE_GFX) $(CMDLINE_CD)
osenv = windows 98
winres = 640x480x16
filter = nonlucas
EXENAME = THOTD
CDLABEL = Hotd
REGLANGUAGE = ENGLISH
REGBLOOD = RED
ISJAPANESE = 0 //if user installed the japanese cd version of the game

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)\CD; optional = true

//
// show warning about blood on japanese cd version
//
warning[blood]:
condition = $(ISJAPANESE)
    text = Choosing red blood color in the in-game options menu (If available) will show corrupted textures on characters. You will need to choose the other blood color options for textures to appear normally.
end

//
// dynamic files
//
dynamicfile[]: path = D:\$(CDLABEL); attributes = 8; contents = $(NULL)


//
// Graphics Driver Select
//
config[graphics]:
	title = Graphics Driver
	option[ddraw]: name = DirectDraw (Software); CMDLINE = -ddraw
	option[d3d]: name = Direct3D (Hardware); CMDLINE = -d3d
	option[d3d-setup]: name = Direct3D (Hardware) Setup; CMDLINE = -d3d -d3d_setup
end

//
// Registry Language Option
//
config[language]:
	title = Language
	option[english]:  name = English; REGLANGUAGE = ENGLISH//;	//locale = en_US
	//option[french]:   name = French; REGLANGUAGE = FRENCH; locale = fr-FR
	//option[german]:   name = German; REGLANGUAGE = GERMAN; locale = de-DE
	option[japanese]: name = Japanese; REGLANGUAGE = JAPANESE; locale = ja-JP
	//option[spanish]:  name = Spanish; REGLANGUAGE = SPANISH; locale = es-ES_tradnl
	//option[italian]:  name = Italian; REGLANGUAGE = ITALIAN; locale = it-IT
	
end

//
// Minimizes the CD Check, CD must still be in the drive
//
config[cd]:
	title = CD Check
	option[check-cd]: name = Check for CD; CMDLINE_CD = $(NULL)
	option[no-cd]: name = No Check; CMDLINE_CD = -cd_nocheck; priority = 1
end

//
// dummy launcher file to satisfy the upgrader
//
//dynamicfile[]: path = $(rootpath)\$(EXENAME).EXE

//
// autoinstaller script
//
script[autoinstaller]:
    condition = is_upgrader()
    code = [[[$(CRLF)
        if (!prop("noautoinstall"))
        {
            input_lockout(true);
            $(AUTOINSTALL_SCRIPT)
            input_lockout(false);
        }
    ]]]
end

//
// Registry
//
script[registry]: code = winregistry_import_file("C:\\DREAMM.REG")
dynamicfile[]:
    path = C:\DREAMM.REG
    contents = [[[$(CRLF)
		REGEDIT4
		[HKEY_LOCAL_MACHINE\SOFTWARE\sega\The House Of The Dead]
		"bloodcolor"="$$(REGBLOOD)"
		"file"="$$(rootpath)\\$(EXENAME).exe"
		"language"="$$(REGLANGUAGE)"
		"path"="$$(rootpath)"
		"RunD3D"="$$(rootpath)\\$(EXENAME).exe\\"-d3d"\\$(CMDLINE_CD)"
		"RunD3DSetup"="$$(rootpath)\\$(EXENAME).exe\\"-d3d -d3d_setup"\\$(CMDLINE_CD)"
		"RunNative"="$$(rootpath)\\$(EXENAME).exe\\"-ddraw"\\$(CMDLINE_CD)"
		[HKEY_LOCAL_MACHINE\SOFTWARE\sega\The House Of The Dead\1.0]
	]]]
end

