//
// The House of the Dead US CD
//
game[pc-cd-en]:
    name = English, Japanese US CD
	imports =  common
    anchorfile = THOTD.exe
	REGBLOOD = RED
	REGLANGUAGE = ENGLISH
	EXENAME = thotd
	CMDLINE_GFX = -ddraw
	CMDLINE_CD = $(NULL)
    file[]: crc = b5a9b6c5; size =   8855552; name = THOTD.exe
    file[]: crc = 06c41bfc; size =     78372; name = SPRITE\spr.rbh
	
