//
// SEGA Swirl
//
desc[sga-swirl]:

name = SEGA Swirl
icon = sga-swirl.png
machine = pc
rootpath = C:\Sega\Swirl
launch = "$(rootpath)\swirl.exe"
osenv = windows 95
winres = 640x480x16
filter = nonlucas

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
//
// video configuration
//
config[video]:
    title = Video Configuration
    option[window]:  name = Cropped to Window; wincrop = true; priority = 1
    option[desktop]: name = Full Desktop;      wincrop = false
end

//
// Common Files
//
fragment[common]:
    file[]: crc = 8c2932f4; size =    132376; name = BOOS.WAV
    file[]: crc = fb462adc; size =    146886; name = CHEERS.WAV
    file[]: crc = c59919b1; size =    176518; name = CHEERS2.WAV
