    file[]: crc = 56ced11c; size =    113748; name = COMBO4B.WAV
    file[]: crc = c4444cd6; size =    196478; name = COMBO5A.WAV
    file[]: crc = e78205ae; size =    109958; name = COMBO5B.WAV
    file[]: crc = fed8f9ba; size =    203780; name = COMBO6A.WAV
    file[]: crc = c4444cd6; size =    196478; name = COMBO6B.WAV
    file[]: crc = cc555c0f; size =    237994; name = COMBO7A.WAV
    file[]: crc = fed8f9ba; size =    203780; name = COMBO7B.WAV
    file[]: crc = fe974e71; size =    330954; name = START.WAV

end

//
// World V1.02
//
game[pc-wd-1.02]:
