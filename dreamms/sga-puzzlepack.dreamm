    file[]: crc = 41cf6ef2; size =   1048584; name = MyGames\Dr. Robotnik's Mean Bean Machine.kvq
    file[]:									  name = ROBOTNIK.TXT
    file[]:									  name = README.TXT
    file[]: crc = 2dc7323b; size =    231082; name = Puzzle.pdf	
	
